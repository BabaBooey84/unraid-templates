<?xml version="1.0"?>
<Container version="2">
  <Name>Sharkord</Name>
  <Repository>sharkord/sharkord:latest</Repository>
  <Registry>https://hub.docker.com/r/sharkord/sharkord</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/Sharkord/sharkord/issues</Support>
  <Project>https://github.com/Sharkord/sharkord</Project>

  <Overview>Sharkord is a self-hosted real-time communication platform.

The container no longer runs as root. It now runs as user "bun" (uid 1000).
Ensure your appdata path is writable by uid 1000 to avoid permission errors.</Overview>

  <Category>Other</Category>
  <WebUI>http://[IP]:[PORT:4991]/</WebUI>
  <Icon>https://raw.githubusercontent.com/Sharkord/sharkord/main/apps/client/public/logo.webp</Icon>

  <!-- Persistent data -->
  <Config
    Name="Appdata"
    Target="/home/bun/.config/sharkord"
    Default="/mnt/user/appdata/sharkord"
    Mode="rw"
    Description="Persistent Sharkord config/data (must be writable by uid 1000)"
    Type="Path"
    Display="always"
    Required="true"
    Mask="false"/>

  <!-- Main UI Port -->
  <Config
    Name="Web UI Port"
    Target="4991"
    Default="4991"
    Mode="tcp"
    Description="Sharkord HTTP/WebSocket port"
    Type="Port"
    Display="always"
    Required="true"
    Mask="false"/>

  <!-- WebRTC TCP -->
  <Config
    Name="WebRTC TCP Port"
    Target="40000"
    Default="40000"
    Mode="tcp"
    Description="WebRTC TCP media port"
    Type="Port"
    Display="always"
    Required="true"
    Mask="false"/>

  <!-- WebRTC UDP -->
  <Config
    Name="WebRTC UDP Port"
    Target="40000"
    Default="40000"
    Mode="udp"
    Description="WebRTC UDP media port (required for voice/video)"
    Type="Port"
    Display="always"
    Required="true"
    Mask="false"/>

</Container>
